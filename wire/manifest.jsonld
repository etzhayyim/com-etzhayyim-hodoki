    {"phase": "R2", "date": "post-R1", "scope": "Pilot ≤10 vehicles/day continuous depollution + parts harvest + shred + cross-actor feed (kanayama + makura + silicon); tatekata-shared yard allocation; right-to-repair parts catalog live.", "murakumoFleet": "naphtali + joseph + levi + simeon + dan + zebulun + judah (7 nodes)", "gate": "ADR-2605261245 (30-day public comment + cross-actor circular feed stand-up)"},
    {"phase": "R3", "date": "post-R2", "scope": "Community-scale ≤500 vehicles/month + ≥95% material recovery + ≥95% F-gas capture + ≥95% PGM yield + 60-day public review.", "murakumoFleet": "Full fleet + Quad logistics", "gate": "ADR-2605261300 (60-day public review + LANDS.md amendment if dedicated yard)"}
  ],
  "constitutionalFirsts": [
    "G8 §2(c) anti-surveillance operationalized for consumer vehicles (mandatory ECU + infotainment + telematics data wipe before any disassembly; parallel to makura G14 + N9 for pillows)",
