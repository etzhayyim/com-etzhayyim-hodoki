  "constitutionalGates": {
    "description": "14 immutable gates per ADR-2605261215. Changes require Council Lv6+ supermajority + new ADR.",
    "gates": {
      "G1": "All depollution + dismantling + shredder firmware + fixture CAD open-source (Apache 2.0 + Charter Rider)",
      "G2": "Mass-balance audit ≥98% closure on kotoba-datomic (input vehicle curb-weight = output parts mass + material-lot mass + emission mass + ASR mass); inherits kanayama G2 pattern",
      "G3": "Every critical step (refrigerant capture, battery disconnect, airbag neutralization, PGM brick removal) signed by witness quorum ≥2 distinct robots (ADR-2605191524)",
      "G4": "All parts catalog entries + recovery reports + take-back records JP + EN bilingual minimum",
      "G5": "All vehicle intakes pass Charter Rider §2(a-h) scan (no military / weapon-carrying / covertly-modified)",
      "G6": "F-gas (HFC / HFO refrigerant) capture ≥95% by mass per vehicle; continuous leak monitoring; no atmospheric venting (UNEP Kigali Amendment alignment)",
      "G7": "Li-ion battery thermal-safety SOP — no puncture, no short-circuit, thermal-runaway-containment enclosure required; SoH measurement per battery + cell where accessible",
      "G8": "CONSTITUTIONAL FIRST: MANDATORY ECU + infotainment + telematics data wipe BEFORE any disassembly; cryptographic destruction attestation with ≥2 robot witness signatures; physical chip-shred fallback if wipe fails. §2(c) anti-surveillance operationalized for consumer vehicles.",
      "G9": "Inference paths (parts ID, defect classification, SoH estimation, fluid type detection) use Murakumo no-VKE mesh only (ADR-2605214000 / ADR-2605215000)",
      "G10": "Refrigerant + airbag + Li-ion + PGM + ECU-shred operations are SBT-gated personnel; non-SBT visitors require 1 SBT = 1 vote Council review",
      "G11": "KPI caps R0–R1: M1 passenger class only, ≤2.5t curb weight, ≤8 seats. N2/N3/N4 = Wave 2 ADR; H2 FCV = Wave 2 ADR; Tesla cell-recovery = Wave 2 ADR. Council Lv6+ to amend.",
      "G12": "CONSTITUTIONAL FIRST: RIGHT-TO-REPAIR INVARIANT — every harvested part has IPFS-pinned catalog entry with VIN provenance + part DID + condition grade + bilingual description + open price discovery; no proprietary lock-in; no anti-disassembly DRM tolerated. §2(e) anti-gatekeeping operationalized at vehicle scale.",
      "G13": "≥95% material recovery rate by mass (target ≥97% by R3); ASR <5% mass to landfill; ASR composition disclosed; cross-actor circular feed mandatory to kanayama + makura + silicon Wave 2",
      "G14": "PGM (Pt / Pd / Rh) recovery yield ≥95% from catalytic converters; cell-level audit of PGM smelter receipts; no PGM leak to ASR fraction"
    }
  },
  "nonGoals": {
    "description": "10 explicitly excluded scopes (constitutional N1–N10, immutable R0–R3)",
    "goals": {
      "N1": "Military vehicles — tanks, MRAPs, AFVs, military trucks, military trailers, military motorcycles. §2(a) constitutional.",
      "N2": "Aerospace vehicles — aircraft, helicopters, drones ≥25 kg MTOW, gliders. Separate aerospace Tier-B if/when.",
      "N3": "Marine vessels — ships, boats, yachts, jet-skis. watatsumi-adjacent or separate ADR.",
      "N4": "Rail rolling stock — locomotives, freight cars, passenger coaches, light-rail. kuni-umi rail-adjacent or separate ADR.",
      "N5": "Buses / trucks ≥3.5t (N2/N3 class commercial vehicles). Wave 2 ADR + Council Lv6+ supermajority.",
      "N6": "Vehicles with proprietary anti-disassembly DRM unless OEM cooperation explicitly granted (refusing DRM circumvention preserves §2(b) constitutional posture).",
      "N7": "VIN-stolen / criminal-provenance vehicles — only documented title chain accepted; Charter scan + Council escalation on suspect intakes.",
      "N8": "Vehicle parts re-sale for re-VIN'ing (chop shop) — every harvested part carries permanent VIN provenance + cannot be used to forge identity of a different vehicle.",
      "N9": "Tesla-class proprietary battery cell harvest without OEM cooperation (cell-level recovery only via Wave 2 ADR).",
      "N10": "Hydrogen fuel-cell vehicles (high-pressure H2 tank disassembly requires Wave 2 ADR with dedicated thermal + pressure safety review)."
    }
  },
