  ],
  "sourceMethodology": "YouTube whyjio70IUU — How Audi Strips Down Thousand of Like-New Expensive Cars Inside Massive Facility (manufacturing methodology adopted; OEM-monopoly right-to-repair-restricting retail layer rejected per §2(e))",
  "scope": {
    "phase": "R0 scaffold",
    "scopeBoundary": "M1 passenger vehicles (≤2.5t curb, ≤8 seats) end-of-life disassembly + materials recovery + parts catalog publication",
    "inScope": [
      "M1 passenger vehicles (≤2.5t curb weight, ≤8 seats)",
      "Powertrains: gasoline ICE / diesel ICE / HEV / PHEV / BEV (NMC / LFP / NCA)",
      "Full chain: intake → depollution → battery handling → parts harvest → catalyst recovery → seat/textile recovery → shred → cross-actor feed"
    ],
    "deferredToWave2PlusViaCouncil": [
      "N2/N3/N4 class (buses, trucks ≥3.5t, semi-trailers)",
      "Hydrogen fuel-cell vehicles (high-pressure H2 tank safety class)",
      "Tesla-class proprietary battery cell harvest without OEM cooperation",
      "E-waste integrated PCB/IC co-processing (separate WEEE ADR)"
    ],
    "exclusions": [
      "Military vehicles (N1)",
      "Aerospace vehicles (N2)",
      "Marine vessels (N3)",
      "Rail rolling stock (N4)",
      "Buses / trucks ≥3.5t (N5)",
      "Vehicles with proprietary anti-disassembly DRM without OEM cooperation (N6)",
      "VIN-stolen / criminal-provenance vehicles (N7)",
      "Part re-sale for re-VIN'ing / chop-shop (N8)",
      "Tesla-class proprietary cell harvest without OEM (N9)",
      "Hydrogen fuel-cell vehicles (N10)"
    ]
  },
  "roboticsClasses": [
    "Hagasu (剥がす) — paint / body-panel stripper (new, R1+); thermal + mechanical detachment",
    "Nuku (抜く) — fluid-drain manipulator (new, R1+); sealed-port fuel / oil / coolant / refrigerant drain for G6 ≥95% F-gas capture",
    "Tokike (解け) — body-fastener releaser (new, R1+); bolt / clip / rivet unfastener with vision-guided targeting; actor namesake",
    "Yokin — kanayama inheritance (R2+ reuse); PGM bench smelter operations",
    "Otete — kuni-umi manipulator (reuse, R0 design); parts handling",
    "Mimi — kuni-umi metrology (reuse, R0 design); SoH measurement + dimensional + condition grading",
    "Quad — kuni-umi logistics (R2+ reuse); vehicle intake transport + ASR drum logistics"
  ],
  "cells": [
    {"name": "elv_intake_audit", "module": "kotodama.cells.elv_intake_audit", "murakumoNode": "naphtali", "phase": "L1a — VIN title + prior-owner consent + Charter §2(a-h) scan + initial data-wipe attestation request"},
    {"name": "elv_depollution", "module": "kotodama.cells.elv_depollution", "murakumoNode": "joseph", "phase": "L1b — fluid drain + MAC refrigerant capture (G6 ≥95%) + airbag pyrotechnic neutralization + battery disconnect"},
    {"name": "elv_battery_handling", "module": "kotodama.cells.elv_battery_handling", "murakumoNode": "levi", "phase": "L2 — Li-ion SoH classification (≥70% second-life → hikari; <70% cell-recycle → Wave 2); lead-acid → kanayama Wave 3"},
    {"name": "elv_parts_harvest", "module": "kotodama.cells.elv_parts_harvest", "murakumoNode": "simeon", "phase": "L3a — reusable parts identification + condition grading + IPFS-pinned catalog publication (G12 right-to-repair)"},
    {"name": "elv_catalyst_recovery", "module": "kotodama.cells.elv_catalyst_recovery", "murakumoNode": "levi", "phase": "L3b — catalytic converter brick removal + PGM smelter handoff + yield audit (G14 ≥95% Pt/Pd/Rh)"},
    {"name": "elv_seat_textile_recovery", "module": "kotodama.cells.elv_seat_textile_recovery", "murakumoNode": "dan", "phase": "L3c — seat foam + textile recovery; cross-actor feed to makura (G13 invariant closure)"},
    {"name": "elv_body_shred", "module": "kotodama.cells.elv_body_shred", "murakumoNode": "zebulun", "phase": "L4 — hulk shredder + magnetic + eddy-current + density sort; ferrous + Al + Cu + ASR streams"},
    {"name": "elv_emissions_audit", "module": "kotodama.cells.elv_emissions_audit", "murakumoNode": "levi", "phase": "cross-cutting — F-gas leakage continuous + ASR mass + composition + PGM yield audit"},
    {"name": "elv_provenance_binder", "module": "kotodama.cells.elv_provenance_binder", "murakumoNode": "judah", "phase": "terminal — full chain DID anchoring on kotoba-datomic (input VIN → parts catalog + material lots + emissions + ASR mass)"}
  ],
