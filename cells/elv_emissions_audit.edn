;; hodoki 解き — elv_emissions_audit cell (cross-cutting)
{:cell/id          "elv_emissions_audit"
 :cell/glyph       "📊"
 :cell/kind        :langgraph
 :cell/runtime     :wasm
 :cell/doc         "Cross-cutting emissions audit — F-gas/ASR/PGM compliance (G6/G13/G14)."
 :cell/gates       ["G1" "G6" "G9" "G13" "G14"]
 :cell/llm         {:provider :murakumo :endpoint "127.0.0.1:4000" :model "gemma3:4b" :charter-rider true}
 :cell/kotoba      {:reads    [:emissions-audit/vin :emissions-audit/f-gas-leakage-continuous
                               :emissions-audit/asr-mass-cap-compliance :emissions-audit/pgm-yield-audit-compliance]
                    :writes   [:emissions-audit/record-id :emissions-audit/vin :emissions-audit/f-gas-leakage-continuous
                               :emissions-audit/asr-mass-cap-compliance :emissions-audit/pgm-yield-audit-compliance
                               :emissions-audit/audit-timestamp]}
 :cell/state-graph {:nodes [{:id "check-fgas" :type "function" :func "check_fgas_compliance"}
                           {:id "check-asr" :type "function" :func "check_asr_compliance"}
                           {:id "check-pgm" :type "function" :func "check_pgm_compliance"}
                           {:id "attest" :type "function" :func "attest_emissions"}
                           {:id "end" :type "return"}]
                    :entry    "check-fgas"
                    :edges    [{:from "check-fgas" :to "check-asr"}
                               {:from "check-asr" :to "check-pgm"}
                               {:from "check-pgm" :to "attest"}
                               {:from "attest" :to "end"}]}}
