 :cell/state-graph {:nodes [{:id "parse-vin" :type "llm-prompt" :prompt "Extract and validate VIN from intake form."}
                           {:id "scan-charter" :type "function" :func "scan_charter_compliance"}
                           {:id "record-intake" :type "function" :func "record_intake"}
