;; hodoki 解き — elv_intake_audit cell (L1a)
{:cell/id          "elv_intake_audit"
 :cell/glyph       "🔍"
 :cell/kind        :langgraph
 :cell/runtime     :wasm
 :cell/doc         "L1a: ELV intake audit — VIN + title + consent + Charter scan (G5)."
 :cell/gates       ["G1" "G5" "G9" "G10"]
