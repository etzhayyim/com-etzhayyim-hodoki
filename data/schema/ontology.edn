 {:db/ident :depollution/airbag-disarmed
  :db/valueType :db.type/boolean
  :db/cardinality :db.cardinality/one
  :db/doc "True if airbags disarmed"}
 {:db/ident :depollution/battery-disconnected
  :db/valueType :db.type/boolean
  :db/cardinality :db.cardinality/one
