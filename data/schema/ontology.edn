;; hodoki 解き — kotoba EAVT schema
;; ADR-2605261215 (R0 scaffold)
;; End-of-life vehicle (ELV) disassembly + materials recovery over kotoba Datoms:
;; intake audit, depollution, battery handling, parts harvest, catalyst recovery,
;; body shred, data wipe, emissions audit, and provenance binding. All state is
;; kotoba Datoms.

[;; ───────────────────────────── :elv-intake/* — ELV Intake Audit Record ─────────────────────────────
 {:db/ident :elv-intake/vin
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/unique :db.unique/identity
  :db/doc "Vehicle Identification Number (VIN)"}
 {:db/ident :elv-intake/title-doc
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/doc "Reference to title documentation (e.g., IPFS CID)"}
 {:db/ident :elv-intake/owner-consent
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/doc "Reference to prior-owner consent record (e.g., DID-signed attestation)"}
 {:db/ident :elv-intake/arrival-timestamp
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/doc "ISO-8601 timestamp of vehicle arrival"}
 {:db/ident :elv-intake/charter-scan-status
  :db/valueType :db.type/keyword
  :db/cardinality :db.cardinality/one
  :db/doc ":passed | :failed — Charter §2(a-h) scan status (G5)"}
 {:db/ident :elv-intake/data-wipe-request
  :db/valueType :db.type/ref
  :db/cardinality :db.cardinality/one
  :db/doc "Reference to initial data wipe attestation request"}

